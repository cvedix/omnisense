# CVR Environment Variables
# See README.md for full list of available variables

# Database
DATABASE_PATH=/var/lib/cvr/cvr.db

# Admin credentials
CVR_ADMIN_USERNAME=admin@localhost
CVR_ADMIN_PASSWORD=P@ssw0rd

# Secret key (generate with: openssl rand -hex 32)
SECRET_KEY_BASE=58xo0WYYV/zY0hF4Ay453xSCUTjvXsh2j4fV8fPGDVl9Ecq58U9Vei4Vm4f486Vp

# Application URL - use 0.0.0.0 to allow access from any IP
CVR_URL=http://localhost:4321
CVR_HTTP_PORT=4321

# Disable origin check to allow access from 127.0.0.1, 192.168.x.x, etc.
CVR_CHECK_ORIGIN=false

# Storage - physical disk mount path for recordings
CVR_STORAGE_PATH=/mnt/storage

# Logging
CVR_JSON_LOGGER=true

# HTTPS (uncomment to enable)
# CVR_ENABLE_HTTPS=true
# CVR_HTTPS_PORT=443
# CVR_SSL_KEY_PATH=/app/data/cert/certificate.key
# CVR_SSL_CERT_PATH=/app/data/cert/certificate.crt