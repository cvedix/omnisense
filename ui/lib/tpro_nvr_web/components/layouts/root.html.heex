<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <head>
      {Application.get_env(:live_debugger, :live_debugger_tags)}
    </head>
    <script>
      // Init dark mode - default to dark mode
      if (localStorage.getItem('dark-mode') === 'false') {
        document.documentElement.classList.remove('dark');
      } else {
        // Default to dark mode when no preference is set
        document.documentElement.classList.add('dark');
      }
    </script>
    <.live_title suffix=" · OmniSense">
      {assigns[:page_title] || "OmniSense"}
    </.live_title>
    <%= if Application.get_env(:live_vue, :vite_host) do %>
      <script type="module" src={"http://#{@conn.host}:5173/@vite/client"}></script>
      <link rel="stylesheet" href={"http://#{@conn.host}:5173/css/app.css"} />
      <script defer type="module" src={"http://#{@conn.host}:5173/js/app.js"}></script>
      <script defer type="module" src={"http://#{@conn.host}:5173/js/webrtc.js"}></script>
    <% else %>
      <link phx-track-static rel="stylesheet" href={static_path(@conn, "/assets/app.css")} />
      <script defer phx-track-static type="module" src={static_path(@conn, "/assets/app.js")}></script>
      <script defer phx-track-static type="module" src={static_path(@conn, "/assets/webrtc.js")}></script>
    <% end %>



  </head>
  <body class="main-body h-full bg-black antialiased">
    {@inner_content}
  </body>
</html>
